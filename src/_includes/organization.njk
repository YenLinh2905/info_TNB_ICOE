<section class="section" id="organization">
  <div class="section-heading">
    <h2>Cơ cấu <span class="accent">tổ chức</span></h2>
  </div>
  <div class="org-tree">
    <div class="org-branches">
      {% for node in organization %}
      <article class="org-node">
        <h3>{{ node.title }}</h3>
        <p>{{ node.description }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
